# Copy to .env and fill in before running `docker compose up`

# atlas-core
SERVER_PORT=8080

# PostgreSQL 16 + pgvector (see docs/adr — embedding dimension couples the
# schema to the embedding model in use). atlas-core's SPRING_DATASOURCE_*
# vars are derived from these in docker-compose.yml.
POSTGRES_USER=atlas
POSTGRES_PASSWORD=changeme
POSTGRES_DB=atlas
POSTGRES_PORT=5432

# LLM / embedding provider
LLM_API_KEY=

# Line-noise stripping applied to parsed page text before chunking (atlas.parsing.strip-line-
# patterns — see ParsingProperties). Empty by default: Atlas core is corpus-agnostic and ships
# no patterns of its own. The three patterns below are demo config for the EU digital-regulation
# corpus (see corpus/README.md) — comma-separated, matched as a FULL line (a partial match doesn't
# strip the line), verified against the exact footer strings pulled from a corpus spot check:
#   1. Old EUR-Lex OJ-style footer, fields in any order, e.g.
#      "4.5.2016 L 119/39 Official Journal of the European Union EN"
#   2. New EUR-Lex ELI-style footer, line 1, e.g. "EN OJ L, 12.7.2024"
#   3. New EUR-Lex ELI-style footer, line 2, e.g.
#      "46/144 ELI: http://data.europa.eu/eli/reg/2024/1689/oj"
# No literal commas appear in any pattern (note \d\d? instead of \d{1,2}) since a literal comma
# would be misread as a boundary between list entries.
ATLAS_PARSING_STRIP_LINE_PATTERNS=^(?=.*Official Journal of the European Union)(?=.*\bEN\b)(?=.*L\s*\d+/\d+)(?=.*\d\d?\.\d\d?\.\d{4}).*$,^EN OJ L.? \d\d?\.\d\d?\.\d{4}$,.*ELI: http://data\.europa\.eu/eli/.*
